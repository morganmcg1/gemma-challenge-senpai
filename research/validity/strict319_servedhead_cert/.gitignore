# Build artifacts: serve copies are regenerated by build_pinned_serve() each run.
_serve_*/
__pycache__/
# Bulky run logs / pidfiles / token dumps (KB-scale jsonl + W&B are the record).
*.out
*.pid
*.log
_inspect_logs/
_serve_bi1/
_serve_fixed2d/
# Keep small result summaries (results/*.json) as committed evidence; drop bulky captures.
results/*_decode.jsonl
results/*.eval
