+# ubel #154 realization (PR #180): argmax-only decode. When enabled, ONLY the
+# spec-verify step (exactly M = K_spec+1 = 8 rows under MAX_NUM_SEQS=1) skips the
+# [M, full_vocab] scatter and returns the pruned [M, K] logits directly; the
+# slim-greedy rejection sampler (serve.py DIXIE_SMP02) argmaxes the pruned head
+# and remaps the winning column back to its real token id via the keepset.
+# Output-identical under greedy: full-vocab argmax always lands on a kept token
+# (non-kept columns are -inf) and keep_ids is sorted ascending so the
+# lowest-index tie-break matches the full-vocab one.
+#
+# Gated on M == _ARGMAX_ONLY_DECODE_VERIFY_M (exact), NOT M <= width, because the
+# M=1 prefill-sample step (the first decoded token) is produced by the regular
+# vLLM sampler, which has no keepset remap — handing it pruned logits would emit
+# a raw pruned column index instead of the real token id (smoke3 bug: tok0=4849,
+# keep_ids[4849]=8291=correct). Only the M=8 verify step flows through the
+# slim-greedy remap, so only it may skip. Every PPL/prompt_logprobs prefill chunk
+# on the 128-record eval set is != 8 tokens (min prefill 390), so the skip never
+# leaks into the full-vocab logprobs path either.
+_ARGMAX_ONLY_DECODE = os.environ.get("ARGMAX_ONLY_DECODE") == "1"
+_ARGMAX_ONLY_DECODE_VERIFY_M = int(os.environ.get("ARGMAX_ONLY_DECODE_VERIFY_M", "8"))
+
