+
+# ubel #154 (PR #180): argmax-only decode. When compute_logits skips the
+# full-vocab scatter on a decode step (serve_patch_pck04.py), the slim-greedy
+# path below receives pruned [M, K] logits, so argmax yields a column in [0, K)
+# that must be remapped to its real token id via the keepset. The keepset tensor
+# is built LAZILY on first use: LM_HEAD_PRUNE repoints PCK04_KEEPSET to the baked
+# 12k keepset before serve, so reading it at module-load is timing-fragile;
+# reading it on the first decode step is guaranteed to see the active keepset
+# (and to match pck04's own K), making the width gate below robust.
+_ARGMAX_ONLY_DECODE = __import__("os").environ.get("ARGMAX_ONLY_DECODE") == "1"
+_argmax_only_keep_cache = {}
+
+
+def _argmax_only_keep_idx(device):
+    cached = _argmax_only_keep_cache.get(device)
+    if cached is not None:
+        return cached
+    import json as _json
+    path = __import__("os").environ.get("PCK04_KEEPSET", "")
+    keep_ids = _json.loads(open(path).read())["keep_ids"]
+    t = torch.as_tensor(keep_ids, dtype=torch.long, device=device)
+    _argmax_only_keep_cache[device] = t
+    __import__("sys").stderr.write(
+        "[dixie] ARGMAX_ONLY_DECODE keepset remap built: K=%d on %s\\n"
+        % (t.shape[0], device)
+    )
+    return t
 """
 
