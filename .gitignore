# Local W&B run-sync dirs. Runs live on the W&B server (we keep the run IDs);
# don't commit the bulky local copies (binary .wandb files + debug logs).
wandb/

# Local working checkout of the Senpai runner fork. The published branch lives
# in wandb/senpai; this repo only stores the challenge workspace.
senpai-aws-compatible/

# Transient local-validation run artifacts (server logs, smoke runs, install logs).
# The canonical greedy reference under research/greedy_reference/ is kept.
research/_localrun/
# Transient serve/profiler logs written beside committed reference artifacts.
research/**/*.log

# STAGE-2b tree-verify probe raw per-node dumps (#71). Bulky and regenerable from
# the env-gated probe; commit the small summary .json verdicts beside them only.
**/treeverify_scratch_nodeargmax*.jsonl

# Local W&B run cache (runs are synced online; the local dir is regenerable).
wandb/
submissions/*/model/

# Live advisor frontier polling state.
research/frontier_watch/
