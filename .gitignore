.env
.credentials
.venv/
*.pem
__pycache__/
*.egg-info/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.DS_Store
.python-version
.scratch

# Local W&B run-sync dirs. Runs live on the W&B server (we keep the run IDs);
# don't commit the bulky local copies (binary .wandb files + debug logs).
wandb/

# Local working checkout of the Senpai runner fork. The published branch lives
# in wandb/senpai; this repo only stores the challenge workspace.
senpai-aws-compatible/

# Transient local-validation run artifacts (server logs, smoke runs, install logs).
# The canonical greedy reference under research/greedy_reference/ is kept.
research/_localrun/
# Transient serve/profiler logs written beside committed reference artifacts.
research/**/*.log

# STAGE-2b tree-verify probe raw per-node dumps (#71). Bulky and regenerable from
# the env-gated probe; commit the small summary .json verdicts beside them only.
**/treeverify_scratch_nodeargmax*.jsonl

# Local W&B run cache (runs are synced online; the local dir is regenerable).
wandb/
submissions/*/model/

# Live advisor frontier polling state.
research/frontier_watch/

# PR #73 greedy-determinism captures. Keep the writeup, scripts, report.json,
# per-run meta/summary provenance, bench results, and a representative raw token
# dump per config (run_00) as a byte-identity anchor -- plus atomic_on/run_01 so
# the positive-control DIVERGENT cross-check (run_00 vs run_01) is reproducible
# with zero GPU. Ignore the transient orchestration runners, the smoke plumbing
# run, the bulky redundant raw token dumps (other run_01+, byte-identical to
# run_00 -- proven in report.json's matrix), and the raw per-token PPL logprob
# dumps (the value lives in ppl.summary.json).
research/validity/greedy_determinism/_*
research/validity/greedy_determinism/captures/*/run_0[1-9]/decode_outputs.jsonl
!research/validity/greedy_determinism/captures/atomic_on/run_01/decode_outputs.jsonl
research/validity/greedy_determinism/captures/**/ppl.jsonl

# splitkv399 full recert (PR #519): the bulky raw decode token streams and raw
# per-token PPL logprob dumps are redundant -- the computed self-determinism
# (65536/65536, 0 flips) lives in <arm>/arm_result.json and the TPS/PPL in the
# *.summary.json + ab_summary.json.
research/validity/splitkv399_full_recert/**/decode_round*.jsonl
research/validity/splitkv399_full_recert/**/ppl.jsonl

# splitkv NUM_SEGMENTS sweep (PR #525): same convention -- keep the computed
# *.summary.json + arm_result.json + sweep_summary.json, drop the bulky raw
# decode token streams, per-token PPL dumps, and the run pidfile.
research/validity/splitkv_numseg_sweep/**/decode_round*.jsonl
research/validity/splitkv_numseg_sweep/**/ppl.jsonl
research/validity/splitkv_numseg_sweep/sweep.pid

# base_fullhead TPS-ceiling (PR #544, analysis-only): same convention -- keep the
# computed serve_results.json + *.summary.json + decomposition.json + head_results
# .json, drop the bulky raw decode token streams and per-token PPL logprob dumps.
research/validity/base_fullhead_tps_ceiling/**/decode_round*.jsonl
research/validity/base_fullhead_tps_ceiling/**/ppl.jsonl

# int4_g128_lmhead downstream-quality gate (PR #579, analysis-only): same
# convention -- keep the per-seed result JSONs + agg579_summary.json + the
# serve/eval/aggregate scripts; drop the bulky inspect_ai .eval transcript logs
# (20M, regenerable -- the slim per-problem records are logged as W&B artifacts and
# the accuracies live in results/*.json), plus transient pidfiles and the done-marker.
research/validity/int4g128_quality_gate/results/_inspect_logs/
research/validity/int4g128_quality_gate/*.pid
research/validity/int4g128_quality_gate/_panel_done

# int4+MTP Option-B quality panel (PR #605/#624/#629, analysis-only): keep the per-seed
# result JSONs (results*/), pooled + verdict JSONs, serve/eval/rollup scripts, and run
# status logs; drop the bulky inspect_ai .eval transcript logs, the serve log (covered by
# research/**/*.log), and transient pidfiles/nohups/ready-markers.
research/validity/int4_mtp_spec_quality_panel/**/_inspect_logs/
research/validity/int4_mtp_spec_quality_panel/*.pid
research/validity/int4_mtp_spec_quality_panel/*.nohup
research/validity/int4_mtp_spec_quality_panel/serve.ready

# bi0 GPQA-Diamond quality gate (PR #773, analysis-only): keep the serve/eval/aggregate
# scripts, per-seed + sanity result JSONs (results/*.json), the pooled verdict JSON, the
# run status log, and the results comment; drop the bulky inspect_ai .eval transcript logs,
# the per-seed inspect stdout dumps, the serve log (covered by research/**/*.log), and
# transient pidfiles/nohups.
research/validity/bi0_gpqa_panel/results/_inspect_logs/
research/validity/bi0_gpqa_panel/*.out
research/validity/bi0_gpqa_panel/*.pid
research/validity/bi0_gpqa_panel/*.nohup
