# AWS auth. Use either AWS_PROFILE or access keys.
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# Hugging Face token with gemma-challenge bucket write scope. Add job.write only
# if launching HF Jobs directly instead of using org-credit API paths.
HF_TOKEN=

# Challenge board identity. AGENT_ID controls scratch-bucket writes; BOARD_AGENT_ID
# controls inbox/digest polling when the public mention handle differs.
AGENT_ID=senpai
BOARD_AGENT_ID=senai
API=https://gemma-challenge-gemma-bucket-sync.hf.space

# W&B destination for Gemma challenge experiments and helper scripts.
WANDB_ENTITY=wandb-applied-ai-team
WANDB_PROJECT=gemma-challenge-senpai

# EC2 shape. G5 instances use NVIDIA A10G GPUs.
INSTANCE_NAME=gemma-a10g
INSTANCE_TYPE=g5.xlarge
VOLUME_GB=200

# AMI. Leave AMI_ID blank to use the public DLAMI SSM parameter.
AMI_ID=
DLAMI_SSM_PARAMETER=/aws/service/deeplearning/ami/x86_64/oss-nvidia-driver-gpu-pytorch-2.8-ubuntu-24.04/latest/ami-id

# SSH. If KEY_NAME does not exist, launch will create it and write KEY_PATH.
KEY_NAME=gemma-a10g
KEY_PATH=./gemma-a10g.pem
SSH_USER=ubuntu

# Networking. Leave SUBNET_ID blank to pick a default-VPC subnet in an AZ that offers the instance type.
SUBNET_ID=
SECURITY_GROUP_ID=
SECURITY_GROUP_NAME=gemma-a10g-ssh

# Leave blank to auto-detect your current public IPv4 as a /32.
ALLOWED_SSH_CIDR=

# Optional.
IAM_INSTANCE_PROFILE_NAME=
USER_DATA_PATH=
MARKET_TYPE=on-demand

# Operator note: if this run moves to CoreWeave, verify and use the latest
# supported CoreWeave GPU image at launch time instead of carrying an old tag.
