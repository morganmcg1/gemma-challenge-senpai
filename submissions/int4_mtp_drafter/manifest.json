{
  "name": "int4-mtp-drafter",
  "description": "int4 W4A16 Gemma-4-E4B target + QAT-matched gemma4_assistant MTP drafter (speculative decoding) for single-stream TPS, greedy-identical.",
  "dependencies": [
    "vllm==0.22.0",
    "transformers==5.9.0"
  ],
  "model_id": "google/gemma-4-E4B-it-qat-w4a16-ct",
  "served_model_name": "gemma-4-e4b-it",
  "port": 8000,
  "serve": [
    "python",
    "serve.py"
  ],
  "env": {
    "DRAFTER_MODEL": "google/gemma-4-E4B-it-qat-q4_0-unquantized-assistant",
    "NUM_SPECULATIVE_TOKENS": "6",
    "MAX_MODEL_LEN": "4096",
    "GPU_MEMORY_UTILIZATION": "0.90",
    "MAX_NUM_BATCHED_TOKENS": "512",
    "MAX_NUM_SEQS": "1",
    "PYTORCH_CUDA_ALLOC_CONF": "expandable_segments:True"
  }
}
